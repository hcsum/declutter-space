generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String    @id @default(uuid())
  name                   String
  email                  String    @unique
  password               String
  imageAnalysisUsedCount Int       @default(0)
  imageAnalysisUsedAt    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  items                  Item[]
}

enum ItemPlan {
  GIVE_AWAY
  DISCARD
  SELL
  KEEP
  UNDECIDED
}

model Item {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  name      String
  pieces    Int
  deadline  DateTime
  startDate DateTime // reset when deadline is changed, display in the reminder email as XXX ago
  plan      ItemPlan
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  image     String?
  reminders ItemReminder[]
}

enum ItemReminderType {
  FIRST
  SECOND
  THIRD
}

model ItemReminder {
  id        String           @id @default(uuid())
  itemId    String
  item      Item             @relation(fields: [itemId], references: [id])
  type      ItemReminderType
  sentAt    DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}
