generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String    @id @default(uuid())
  name                   String
  email                  String    @unique
  password               String
  stripeCustomerId       String?
  imageAnalysisUsedCount Int       @default(0)
  imageAnalysisUsedAt    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  isVerified             Boolean   @default(false)
  items                  Item[]
  checklistLists         ChecklistList[]
  checklistItems         ChecklistItem[]
  checklistCompletions   ChecklistCompletion[]
  checklistPreference    ChecklistPreference?

  membership Membership[]
  categories Category[]
}

enum ChecklistListSource {
  PRESET
  IMPORTED
}

enum ChecklistItemSource {
  PRESET
  CUSTOM
  IMPORTED
}

enum ItemPlan {
  GIVE_AWAY
  DISCARD
  SELL
  KEEP
  UNDECIDED
}

model Item {
  id         String         @id @default(uuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  name       String
  pieces     Int
  deadline   DateTime
  startDate  DateTime // reset when deadline is changed, display in the reminder email as XXX ago
  plan       ItemPlan
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  archivedAt DateTime?
  image      String?
  reminders  ItemReminder[]
  category   Category?      @relation(fields: [categoryId], references: [id])
  categoryId String?
}

enum ItemReminderType {
  FIRST
  SECOND
  THIRD
}

model Category {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     Item[]
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, name])
}

// not in use yet
model ItemReminder {
  id        String           @id @default(uuid())
  itemId    String
  item      Item             @relation(fields: [itemId], references: [id])
  type      ItemReminderType
  sentAt    DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Membership {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id])
  stripeSubscriptionId String? // Stripe subscription ID (starts with 'sub_')
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ChecklistList {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  key       String
  title     String
  source    ChecklistListSource
  isActive  Boolean             @default(true)
  items     ChecklistItem[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, key])
  @@index([userId, isActive])
}

model ChecklistItem {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id])
  listId      String
  list        ChecklistList       @relation(fields: [listId], references: [id])
  itemKey     String
  entryKey    String
  text        String
  source      ChecklistItemSource
  isActive    Boolean             @default(true)
  archivedAt  DateTime?
  completions ChecklistCompletion[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([userId, entryKey])
  @@unique([listId, itemKey])
  @@index([userId, isActive])
}

model ChecklistCompletion {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  itemId      String
  item        ChecklistItem @relation(fields: [itemId], references: [id])
  completedOn DateTime
  createdAt   DateTime      @default(now())

  @@unique([userId, itemId, completedOn])
  @@index([userId, completedOn])
}

model ChecklistPreference {
  userId                String   @id
  user                  User     @relation(fields: [userId], references: [id])
  hasSeenMomentumDialog Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
